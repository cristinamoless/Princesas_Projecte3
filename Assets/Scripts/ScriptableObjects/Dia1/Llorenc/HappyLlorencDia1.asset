  m_Name: HappyLlorencDia1
  m_EditorClassIdentifier: 
  characterName: "Lloren\xE7"
  characterPixel: {fileID: 21300000, guid: cd023a3636c8df947b5219f139559952, type: 3}
  sentences:
  - "Wow, fan molt bona olor, m\u2019agrada molt! Li regalar\xE9 a la meva mare.\r\n\n"
  - "Escolta, passat dem\xE0 a la tarda pel forn i et convido a un caf\xE8 i un pastisset.
    Si vols \xE9s clar."
  day: 1
  orderIndex: 2
  type: 4
  choices:
  - choiceText: "Sona genial, Lloren\xE7. Dem\xE0 ens veiem doncs."
    nextDialogue: {fileID: 11400000, guid: b861e4f80da0e0e4d8fa95ff6980534e, type: 2}
  - choiceText: "No, ho s\xE9\u2026 Amb la mudan\xE7a i tot tinc bastanta feina,
      per\xF2 em passar\xE9 a saludar!"
    nextDialogue: {fileID: 11400000, guid: 2eb5aaa69b3392b4dbab085a242b8c91, type: 2}
